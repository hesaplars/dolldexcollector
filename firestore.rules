rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidUsername(username) {
      return username.size() >= 3
        && username.size() <= 15
        && username.matches('^[a-z0-9_]+$');
    }

    function isThreadMember(threadId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.memberIds;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAdmin()
        || (isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'isPro', 'proUntil']));
      allow delete: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn() && isValidUsername(username) && request.resource.data.userId == request.auth.uid && request.resource.data.username == username;
      allow update: if signedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && request.resource.data.username == username;
      allow delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /accountDeletionRequests/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /characters/{characterId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sets/{setId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pets/{petId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /accessories/{accessoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /collectionEntries/{entryId} {
      allow read: if (!('visibility' in resource.data) || resource.data.visibility == 'public')
        || isOwner(resource.data.userId)
        || isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin()
        || isOwner(resource.data.reporterId);
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update: if isOwner(resource.data.userId);
      allow create: if signedIn();
      allow delete: if signedIn()
        && (isOwner(resource.data.userId) || isAdmin());
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.fromUserId
          || request.auth.uid == resource.data.toUserId
          || isAdmin());
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if signedIn()
        && (request.auth.uid == resource.data.toUserId || isAdmin());
      allow delete: if signedIn()
        && (request.auth.uid == resource.data.fromUserId
          || request.auth.uid == resource.data.toUserId
          || isAdmin());
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if signedIn()
        && (request.auth.uid == resource.data.followerId || isAdmin());
      allow update: if false;
    }

    match /blocks/{blockId} {
      allow read: if signedIn()
        && (resource.data.blockerId == request.auth.uid || isAdmin());
      allow create: if signedIn()
        && request.resource.data.blockerId == request.auth.uid;
      allow delete: if signedIn()
        && (resource.data.blockerId == request.auth.uid || isAdmin());
      allow update: if false;
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if false;
    }

    match /chatThreads/{threadId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.memberIds;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if signedIn()
        && request.auth.uid in resource.data.memberIds;
      allow delete: if isAdmin();
    }

    match /chatMessages/{messageId} {
      allow read: if isThreadMember(resource.data.threadId);
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && isThreadMember(request.resource.data.threadId);
      allow update, delete: if isAdmin();
    }

    match /globalChatMessages/{messageId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isOwner(subscriptionId) || isAdmin();
      allow write: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
